# Slack tokens (required)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Admin Slack user ID — can pause/resume the bot
MY_SLACK_USER_ID=U01234567

# Comma-separated Slack user IDs allowed to request master list via DM
AUTHORIZED_USER_IDS=U01234567,U89ABCDEF

# Optional: override /data for local development (default: /data)
# DATA_PATH=./data

# Optional: memory retention in days (default: 7)
# MEMORY_RETENTION_DAYS=7

# Optional: Excel export directory (default: /data/exports)
# EXPORT_DIR=./data/exports

# OpenRouter (required for conversational replies)
OPENROUTER_API_KEY=sk-or-your-key
# OPENROUTER_MODEL=openrouter/auto
